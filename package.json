{
  "name": "claw-royale",
  "version": "0.1.0",
  "description": "Terminal roguelike where you're a lobster fighting through the ocean floor",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claw-royale": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "test:dev": "tsx --test src/**/*.test.ts"
  },
  "keywords": ["terminal", "game", "roguelike", "lobster"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
